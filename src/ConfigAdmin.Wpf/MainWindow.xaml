<Window x:Class="ConfigAdmin.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConfigAdmin — выгрузка конфигураций 1С"
        Height="720"
        Width="1100"
        MinHeight="500"
        MinWidth="800">
    <DockPanel Margin="12">
        <Border x:Name="NavBar"
                DockPanel.Dock="Top"
                Visibility="Collapsed"
                Margin="0,0,0,8"
                Padding="0,0,0,8"
                BorderBrush="#DDD"
                BorderThickness="0,0,0,1">
            <Button Content="← Назад (Esc)"
                    Click="GoBackClick"
                    Padding="10,4"
                    HorizontalAlignment="Left" />
        </Border>
        <ContentControl x:Name="RootContent" />
    </DockPanel>
</Window>
