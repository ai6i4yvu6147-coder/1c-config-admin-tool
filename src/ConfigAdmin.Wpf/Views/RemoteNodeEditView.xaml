<UserControl x:Class="ConfigAdmin.Wpf.Views.RemoteNodeEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:ConfigAdmin.Wpf.Behaviors">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640">
            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

            <TextBlock Text="Node ID" />
            <TextBox Text="{Binding NodeIdText, Mode=OneWay}" IsReadOnly="True" Margin="0,4,0,12" Background="#F5F5F5" />

            <TextBlock Text="Клиент" />
            <ComboBox ItemsSource="{Binding Clients}"
                      SelectedValue="{Binding SelectedClientId}"
                      SelectedValuePath="Id"
                      DisplayMemberPath="Name"
                      Margin="0,4,0,12" />

            <TextBlock Text="Имя узла" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />

            <TextBlock Text="Описание" />
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />

            <TextBlock Text="Pairing-пароль" />
            <PasswordBox x:Name="PairingPasswordBox"
                         Margin="0,4,0,12"
                         behaviors:PasswordBoxBindingBehavior.Attach="True"
                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding PairingPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock Text="URL для Передатчика на RDP" />
            <TextBox Text="{Binding HubListenUrlHint, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,4" />
            <TextBlock Text="Подсказка: замените &lt;Tailscale-IP&gt; на IP вашего Hub в VPN."
                       TextWrapping="Wrap"
                       Foreground="Gray"
                       Margin="0,0,0,12" />

            <CheckBox Content="Узел включён" IsChecked="{Binding Enabled}" Margin="0,0,0,12" />

            <TextBlock Text="{Binding StatusMessage}" Foreground="Firebrick" TextWrapping="Wrap" Margin="0,0,0,12" />

            <StackPanel Orientation="Horizontal">
                <Button Content="Сохранить" Command="{Binding SaveCommand}" Padding="10,4" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
