<UserControl x:Class="ConfigAdmin.Wpf.Views.McpHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ConfigAdmin.Wpf.Views">
    <TabControl>
        <TabItem Header="Конфигурации (config-mcp)">
            <views:ConfigMcpView DataContext="{Binding ConfigMcp}" />
        </TabItem>
        <TabItem Header="Данные (data-mcp)">
            <views:DataMcpView DataContext="{Binding DataMcp}" />
        </TabItem>
    </TabControl>
</UserControl>
