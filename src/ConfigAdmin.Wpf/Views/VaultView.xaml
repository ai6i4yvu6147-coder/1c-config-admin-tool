<UserControl x:Class="ConfigAdmin.Wpf.Views.VaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:ConfigAdmin.Wpf.Behaviors"
             Loaded="OnLoaded">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Padding="32" BorderBrush="#CCC" BorderThickness="1" CornerRadius="8" MaxWidth="480">
            <StackPanel>
                <TextBlock Text="ConfigAdmin" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="Выгрузка конфигураций и расширений 1С" FontSize="13" Foreground="Gray"
                           HorizontalAlignment="Center" Margin="0,0,0,20" />

                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

                <TextBlock Text="Мастер-пароль" Margin="0,0,0,4" />
                <PasswordBox x:Name="MasterPasswordBox"
                             Margin="0,0,0,12"
                             Padding="4"
                             behaviors:PasswordBoxBindingBehavior.Attach="True"
                             behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding MasterPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                <StackPanel Visibility="{Binding IsInitialized, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="Подтверждение пароля" Margin="0,0,0,4" />
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Margin="0,0,0,12"
                                 Padding="4"
                                 behaviors:PasswordBoxBindingBehavior.Attach="True"
                                 behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource ErrorTextStyle}" Margin="0,0,0,12" />

                <Button Content="{Binding SubmitButtonText}" Command="{Binding SubmitCommand}" Padding="14,8" FontSize="14" />

                <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" Foreground="Gray" FontSize="12"
                           Text="Мастер-пароль защищает сохранённые пароли баз. Он не хранится на диске." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
