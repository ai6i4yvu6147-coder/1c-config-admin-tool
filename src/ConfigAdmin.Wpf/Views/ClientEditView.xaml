<UserControl x:Class="ConfigAdmin.Wpf.Views.ClientEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="{StaticResource FormMaxWidth}">
            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

            <TextBlock Text="Имя клиента" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />

            <TextBlock Text="Корневой каталог выгрузки" />
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding ExportRootPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Обзор..." Command="{Binding BrowseExportRootCommand}" Padding="10,4" />
            </Grid>

            <TextBlock Text="Комментарий" />
            <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />

            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource ErrorTextStyle}" Margin="0,0,0,12" />

            <Button Content="Сохранить" Command="{Binding SaveCommand}" Style="{StaticResource ToolbarButtonStyle}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
