<UserControl x:Class="ConfigAdmin.Wpf.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="680">
            <TextBlock Text="Выгрузка" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding BaseDisplayName}" FontSize="14" Margin="0,0,0,16" />

            <TextBlock Text="План выгрузки (из настроек базы)" FontWeight="SemiBold" Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding ExportPlanItems}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      Margin="0,0,0,12"
                      MinHeight="100">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Конфигурация" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="Тип" Binding="{Binding KindLabel}" Width="100" />
                    <DataGridTextColumn Header="Имя в конфигураторе" Binding="{Binding DesignerName}" Width="160" />
                </DataGrid.Columns>
            </DataGrid>

            <CheckBox Content="Синхронизировать с config-mcp после выгрузки"
                      IsChecked="{Binding SyncToMcpAfterExport}"
                      IsEnabled="{Binding IsMcpSyncAvailable}"
                      Margin="0,0,0,16" />

            <TextBlock Text="{Binding ProgressText}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <ProgressBar Height="8" Margin="0,0,0,8"
                         IsIndeterminate="{Binding IsBusy}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="Firebrick" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Text="{Binding McpFollowUpText}" TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,16" />

            <StackPanel Orientation="Horizontal">
                <Button Content="Выгрузить"
                        Command="{Binding ExportCommand}"
                        Padding="12,6" Margin="0,0,8,0"
                        Visibility="{Binding IsLocalBase, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Выгрузить и синхронизировать с RDP"
                        Command="{Binding RemoteSyncCommand}"
                        Padding="12,6" Margin="0,0,8,0"
                        Visibility="{Binding IsRemoteBase, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Назад" Command="{Binding BackCommand}" Padding="12,6" />
            </StackPanel>

            <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" Foreground="Gray"
                       Text="План настраивается в карточке базы. Remote: одна sync-задача на каждую конфигурацию в плане." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
