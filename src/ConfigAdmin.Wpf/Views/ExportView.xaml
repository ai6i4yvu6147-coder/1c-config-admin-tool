<UserControl x:Class="ConfigAdmin.Wpf.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="680">
            <TextBlock Text="Выгрузка" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="{Binding BaseDisplayName}" FontSize="14" Margin="0,0,0,16" />

            <TextBlock Text="Что выгружать" FontWeight="SemiBold" Margin="0,0,0,8" />

            <CheckBox Content="Основная конфигурация (может занять много времени на больших базах)"
                      IsChecked="{Binding ExportConfiguration}" Margin="0,0,0,8" />

            <CheckBox Content="Все расширения (-AllExtensions)"
                      IsChecked="{Binding ExportAllExtensions}" Margin="0,0,0,8" />

            <TextBlock Text="Выбранные расширения (по одному на строку, -Extension)" Margin="0,0,0,4" />
            <TextBox Text="{Binding SelectedExtensionsText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" Height="90" Margin="0,0,0,12"
                     IsEnabled="{Binding IsSelectedExtensionsEnabled}" />

            <CheckBox Content="Сохранить эти настройки в профиле базы"
                      IsChecked="{Binding SaveSettingsToProfile}" Margin="0,0,0,8" />

            <CheckBox Content="Синхронизировать с config-mcp после выгрузки конфигурации"
                      IsChecked="{Binding SyncToMcpAfterExport}"
                      IsEnabled="{Binding IsMcpSyncAvailable}"
                      Margin="0,0,0,16" />

            <TextBlock Text="{Binding ProgressText}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="Firebrick" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Text="{Binding McpFollowUpText}" TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,16" />

            <StackPanel Orientation="Horizontal">
                <Button Content="Выгрузить" Command="{Binding ExportCommand}" Padding="12,6" Margin="0,0,8,0"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                <Button Content="Назад" Command="{Binding BackCommand}" Padding="12,6" />
            </StackPanel>

            <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" Foreground="Gray"
                       Text="Расширение: {каталог базы}\{имя расширения}. Конфигурация: {каталог базы}\Основная конфигурация. При выгрузке только расширений папка конфигурации не затрагивается." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
