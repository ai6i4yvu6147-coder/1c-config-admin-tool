<UserControl x:Class="ConfigAdmin.Wpf.Views.ConfigMcpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="MCP конфигураций (config-mcp)" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

            <TextBlock Text="Путь к portable config-mcp" FontWeight="SemiBold" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}" Padding="4" Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Сохранить путь" Command="{Binding SavePathCommand}" Padding="10,4" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Открыть каталог" Command="{Binding OpenPortableCommand}" Padding="10,4" />
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Обновить статус" Command="{Binding RefreshCommand}" Padding="10,4" Margin="0,0,8,0" />
                <Button Content="Привязать" Command="{Binding LinkCommand}" Padding="10,4" Margin="0,0,8,0" FontWeight="SemiBold" />
                <Button Content="Синхронизировать выбранную" Command="{Binding SyncSelectedCommand}" Padding="10,4" Margin="0,0,8,0" />
                <Button Content="Синхронизировать все привязанные" Command="{Binding SyncAllCommand}" Padding="10,4" Margin="0,0,8,0" />
                <Button Content="Журнал событий" Command="{Binding OpenJournalCommand}" Padding="10,4" Margin="0,0,8,0" />
                <Button Content="Назад" Command="{Binding BackCommand}" Padding="10,4" />
            </StackPanel>

            <TextBlock Text="Выберите конфигурацию (база или расширение), проект и database MCP. «Привязать» сразу пишет в projects.json — каталог выгрузки может ещё не существовать; он появится при первой выгрузке."
                       TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,8" />

            <TextBlock Text="{Binding StatusSummary}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding RegistryFilePath}" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,4" />
            <TextBlock Text="{Binding McpReadiness}" Foreground="Gray" Margin="0,0,0,4" />
            <TextBlock Text="Статус (можно копировать)" FontWeight="SemiBold" Margin="0,0,0,2" />
            <TextBox Text="{Binding StatusMessage, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     MinHeight="40"
                     MaxHeight="120"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,4" />
            <TextBox Text="{Binding FollowUpText, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     MaxHeight="80"
                     VerticalScrollBarVisibility="Auto"
                     Foreground="#555"
                     Margin="0,0,0,8" />
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <TextBlock DockPanel.Dock="Top" Text="Конфигурации (база / расширения)" FontWeight="SemiBold" Margin="0,0,0,4" />
                <DataGrid ItemsSource="{Binding ConfigInstances}"
                          SelectedItem="{Binding SelectedInstance}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Клиент / База / Конфигурация" Binding="{Binding DisplayLabel}" Width="*" />
                        <DataGridTextColumn Header="Тип" Binding="{Binding KindLabel}" Width="90" />
                        <DataGridTextColumn Header="Привязка MCP" Binding="{Binding LinkStatus}" Width="220" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <DockPanel Grid.Row="2">
                <TextBlock DockPanel.Dock="Top" Text="Проекты config-mcp" FontWeight="SemiBold" Margin="0,0,0,4" />
                <DataGrid ItemsSource="{Binding McpProjects}"
                          SelectedItem="{Binding SelectedMcpProject}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Проект" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Баз" Binding="{Binding DatabaseCount}" Width="60" />
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding Active}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <DockPanel Grid.Row="4">
                <TextBlock DockPanel.Dock="Top" Text="Databases config-mcp" FontWeight="SemiBold" Margin="0,0,0,4" />
                <DataGrid ItemsSource="{Binding McpDatabases}"
                          SelectedItem="{Binding SelectedMcpDatabase}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Проект / Имя" Binding="{Binding DisplayLabel}" Width="*" />
                        <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="80" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding StatusLabel}" Width="220" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
