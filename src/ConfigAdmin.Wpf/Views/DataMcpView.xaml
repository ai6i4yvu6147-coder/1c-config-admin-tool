<UserControl x:Class="ConfigAdmin.Wpf.Views.DataMcpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:ConfigAdmin.Wpf.Behaviors">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="MCP данных (data-mcp)" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

            <TextBlock Text="Путь к portable data-mcp" FontWeight="SemiBold" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}" Padding="4" Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Сохранить путь" Command="{Binding SavePathCommand}" Padding="10,4" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Открыть каталог" Command="{Binding OpenPortableCommand}" Padding="10,4" />
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Обновить статус" Command="{Binding RefreshCommand}" Padding="10,4" />
            </StackPanel>

            <TextBlock Text="{Binding StatusSummary}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding McpReadiness}" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Text="{Binding VaultHint}" Style="{StaticResource HintTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12" />

            <Separator Margin="0,0,0,12" />

            <TextBlock Text="Настройки Hub (локально)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="{Binding HubSettingsHint}"
                       Style="{StaticResource HintTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />

            <TextBlock Text="Глобальный bucket (S3)" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="Endpoint" />
            <TextBox Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
            <TextBlock Text="Region" />
            <TextBox Text="{Binding Region, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
            <TextBlock Text="Bucket" />
            <TextBox Text="{Binding Bucket, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
            <TextBlock Text="Default prefix" />
            <TextBox Text="{Binding DefaultPrefix, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
            <TextBlock Text="Sealed secrets path" />
            <TextBox Text="{Binding SealedSecretsPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />

            <TextBlock Text="D-MCP password (managed)" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Для разблокировки credentials.sealed.json на portable. Не передаётся агенту."
                       Style="{StaticResource HintTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4" />
            <PasswordBox Margin="0,4,0,16"
                         behaviors:PasswordBoxBindingBehavior.Attach="True"
                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding DmcpPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <TextBlock Text="Связи инфобаз (pairing)" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Вставьте databaseid из 1С processing. Один databaseid на инфобазу."
                       Style="{StaticResource HintTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding Connections}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      MinHeight="160"
                      Margin="0,0,0,12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="120" IsReadOnly="True" />
                    <DataGridTextColumn Header="Инфобаза" Binding="{Binding InfobaseName}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="databaseid" Binding="{Binding DatabaseId, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                    <DataGridTextColumn Header="display_name" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                    <DataGridCheckBoxColumn Header="Paired" Width="70" IsReadOnly="True">
                        <DataGridCheckBoxColumn.Binding>
                            <Binding Path="IsPaired" Mode="OneWay" />
                        </DataGridCheckBoxColumn.Binding>
                    </DataGridCheckBoxColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Button Content="Сохранить в Hub"
                    Command="{Binding SaveHubCommand}"
                    Padding="12,6"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16" />

            <Separator Margin="0,0,0,12" />

            <TextBlock Text="Синхронизация с portable (D-MCP CLI)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="{Binding PortableSyncHint}"
                       Style="{StaticResource HintTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />

            <TextBlock Text="S3 keys (для apply-secrets)" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="{Binding SealedCredentialsHint}"
                       Style="{StaticResource HintTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
            <TextBlock Text="Access Key ID" />
            <TextBox Text="{Binding AccessKeyId, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding S3AccessKeyPlaceholder}"
                     Margin="0,4,0,8" />
            <TextBlock Text="Secret Access Key" />
            <PasswordBox Margin="0,4,0,12"
                         ToolTip="{Binding S3SecretKeyPlaceholder}"
                         behaviors:PasswordBoxBindingBehavior.Attach="True"
                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding SecretAccessKey, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <Button Content="Синхронизировать portable"
                    Command="{Binding SyncPortableCommand}"
                    Padding="12,6"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12" />

            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource ErrorTextStyle}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
