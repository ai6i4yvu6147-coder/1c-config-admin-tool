<Application x:Class="ConfigAdmin.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ConfigAdmin.Wpf.Converters"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             Startup="OnStartup"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <sys:Double x:Key="FormMaxWidth">640</sys:Double>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Firebrick" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,4" />
        </Style>
    </Application.Resources>
</Application>